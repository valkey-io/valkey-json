        "group": "json",
        "module_since": "1.0.0",
        "arity": -3,
        "acl_categories": [
            "READ",
            "FAST",
            "JSON"
        ],
        "arguments": [
            {
                "name": "key",
                "type": "key",
                "multiple": true,
                "key_spec_index": 0
            },
            {
                "name": "path",
                "type": "string"
            }
        ]
    }
}